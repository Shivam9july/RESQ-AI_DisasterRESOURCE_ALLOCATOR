# Resq Frontend environment variables (Vite).
# Copy to `.env` for local dev, or set these in your Vercel project settings.

# Production backend URL on Render (no trailing slash).
# Example: https://resq-backend-xxxx.onrender.com/api
VITE_API_BASE_URL=https://your-render-backend.onrender.com/api

# For LOCAL development, leave this UNSET — the app uses the Vite proxy (/api)
# so cookies work on the same origin. Do NOT set this to 127.0.0.1:8000 in the
# browser or cross-origin cookies will break login.
