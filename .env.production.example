RESQ_DEBUG=false
RESQ_SECRET_KEY=replace-with-a-long-random-secret-key-at-least-50-characters
RESQ_ALLOWED_HOSTS=api.example.com
RESQ_CORS_ALLOWED_ORIGINS=https://app.example.com
RESQ_CSRF_TRUSTED_ORIGINS=https://app.example.com
DATABASE_URL=postgresql://resq_user:replace-password@db.example.com:5432/resq
RESQ_SECURE_SSL_REDIRECT=true
RESQ_SESSION_COOKIE_SECURE=true
RESQ_CSRF_COOKIE_SECURE=true
RESQ_SECURE_HSTS_SECONDS=31536000
RESQ_SECURE_HSTS_INCLUDE_SUBDOMAINS=true
RESQ_SECURE_HSTS_PRELOAD=true
VITE_API_BASE_URL=https://api.example.com/api
